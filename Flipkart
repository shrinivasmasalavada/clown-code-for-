<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Flipkart Clone</title>
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f1f3f6;
    }

    /* Header */
    header {
        background: #2874f0;
        color: white;
        padding: 10px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo {
        font-size: 22px;
        font-weight: bold;
    }

    .search-box input {
        width: 400px;
        padding: 8px;
        border: none;
        border-radius: 2px;
    }

    .login-btn {
        background: white;
        color: #2874f0;
        padding: 8px 15px;
        border: none;
        cursor: pointer;
        font-weight: bold;
    }

    /* Categories */
    .categories {
        display: flex;
        justify-content: space-around;
        background: white;
        padding: 10px;
    }

    .cat {
        text-align: center;
        font-size: 14px;
        cursor: pointer;
    }

    /* Banner */
    .banner {
        margin: 10px;
    }

    .banner img {
        width: 100%;
        border-radius: 5px;
    }

    /* Products */
    .products {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        padding: 15px;
    }

    .card {
        background: white;
        padding: 10px;
        border-radius: 5px;
        text-align: center;
    }

    .card img {
        width: 100%;
        height: 150px;
        object-fit: cover;
    }

    .price {
        color: green;
        font-weight: bold;
    }

    button {
        background: #fb641b;
        color: white;
        border: none;
        padding: 8px;
        margin-top: 5px;
        cursor: pointer;
        width: 100%;
    }

    button:hover {
        background: #e55b17;
    }
</style>
</head>

<body>

<header>
    <div class="logo">Flipkart</div>
    <div class="search-box">
        <input type="text" placeholder="Search for products, brands and more">
    </div>
    <button class="login-btn">Login</button>
</header>

<div class="categories">
    <div class="cat">Mobiles</div>
    <div class="cat">Fashion</div>
    <div class="cat">Electronics</div>
    <div class="cat">Home</div>
    <div class="cat">Appliances</div>
    <div class="cat">Travel</div>
</div>

<div class="banner">
    <img src="https://via.placeholder.com/1200x300">
</div>

<div class="products">

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <p>Smartphone</p>
        <p class="price">₹12,999</p>
        <button>Add to Cart</button>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <p>Laptop</p>
        <p class="price">₹45,000</p>
        <button>Add to Cart</button>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <p>Headphones</p>
        <p class="price">₹1,499</p>
        <button>Add to Cart</button>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <p>Watch</p>
        <p class="price">₹999</p>
        <button>Add to Cart</button>
    </div>

</div>

<script>
    const buttons = document.querySelectorAll("button");

    buttons.forEach(btn => {
        btn.addEventListener("click", () => {
            alert("Added to cart!");
        });
    });
</script>

</body>
</html>